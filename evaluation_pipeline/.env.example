# ── Backend selection ──────────────────────────────────────────────────────────
# "openai"       → OpenAI-compatible endpoint (Azure AI Foundry MaaS, vLLM…)
# "azure_openai" → Azure OpenAI service (cognitiveservices.azure.com)
# "local_qwen"   → locally-served HF Transformers Qwen3.5-0.8B
# "ollama"       → local Ollama server
EVALUATOR_BACKEND=openai
VERIFIER_BACKEND=azure_openai

# ── Evaluator – LLaMA on Azure AI Foundry (MaaS / openai-compatible) ──────────
EVALUATOR_MODEL=llama-evaluator
EVALUATOR_API_BASE=https://your-foundry-endpoint.services.ai.azure.com/openai/v1/
EVALUATOR_API_KEY=your-evaluator-api-key

# ── Verifier – GPT-5.4-mini on Azure OpenAI service ───────────────────────────
VERIFIER_MODEL=gpt_verifier
VERIFIER_AZURE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
VERIFIER_AZURE_DEPLOYMENT=gpt_verifier
VERIFIER_AZURE_API_VERSION=2024-12-01-preview
VERIFIER_AZURE_API_KEY=your-verifier-api-key

# ── Local Qwen3.5-0.8B (inactive – kept for reference) ────────────────────────
# Set VERIFIER_BACKEND=local_qwen and start:
#   transformers serve Qwen/Qwen3.5-0.8B --port 8000 --continuous-batching
# LOCAL_QWEN_API_BASE=http://localhost:8000/v1
# LOCAL_QWEN_API_KEY=EMPTY

# ── Ollama fallback ────────────────────────────────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434

MAX_ITERATIONS=2
