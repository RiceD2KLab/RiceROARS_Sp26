# ═══════════════════════════════════════════════════════════════════════════════
# IT / operations — deployment handoff
# ═══════════════════════════════════════════════════════════════════════════════
#
# Full hosting steps: see the README section "Deployment (IT / operations)".
#
# Build the app image from the repository root:
#   docker build -t roars .
#
# Run locally with this file copied to `.env` beside it (never commit real keys):
#   docker run --rm -p 3000:3000 --env-file evaluation_pipeline/.env roars
#
# In Azure (or similar), copy the variables below into the web app’s application
# settings or a secret store (e.g. Key Vault); do not bake secrets into the image.
#
# Optional (Next.js API / container): ROAR_PIPELINE_TIMEOUT_MS (default 300000),
# PYTHON if the interpreter is not `python3` on PATH.
#
# ═══════════════════════════════════════════════════════════════════════════════
#
# PRODUCTION PIPELINE (team final — MS3 strict + Prompt Set B)
# ───────────────────────────────────────────────────────────────────────────────
#   • Model profile: DeepSeek-V3.2 (evaluator, Azure AI Foundry MaaS)
#   • Verifier:      o1-mini (Azure OpenAI / cognitiveservices.azure.com)
#   • Prompt set B:  Chain-of-Thought Evidence Anchoring
#   • Strict eval:   “good” ROAR = all four section scores = 1 (see strictAllPass
#                    in API JSON); weighted score is still returned for reference.
#
# Copy this file to `evaluation_pipeline/.env` and fill in secrets. You may also
# place a `.env` at the repository root with the same variables.
#
# ═══════════════════════════════════════════════════════════════════════════════

# ── Pipeline profile (scripts/run_roar_evaluation.py + Next.js API) ────────────
# Prompt set keys: A_DisqualifierFirst | B_ChainOfThought | C_FewShot
ROAR_PROMPT_SET=B_ChainOfThought

# Model profile keys: MS1_LLaMA_GPTmini | MS2_o4mini_GPT41 | MS3_DeepSeek_o4mini | MS3_DeepSeek_o1mini
# MS3_DeepSeek_o1mini is an alias for MS3 (DeepSeek + o1-mini verifier).
ROAR_MODEL_PROFILE=MS3_DeepSeek_o1mini

# strict = team’s final labeling rule (all sections must pass). weighted = legacy ≥50% rule.
ROAR_CLASSIFICATION_STRATEGY=strict

MAX_ITERATIONS=2

# ── Backend selection (overridden by ROAR_MODEL_PROFILE for API bridge) ────────
# Evaluator: openai-compatible Azure AI Foundry MaaS for DeepSeek-V3.2
EVALUATOR_BACKEND=openai
# Verifier: Azure OpenAI (cognitiveservices.azure.com) for o1-mini
VERIFIER_BACKEND=azure_openai

# ── Evaluator — DeepSeek-V3.2 (Azure AI Foundry MaaS, OpenAI-compatible) ─────────
# Deployment name must match your Foundry model deployment (example below).
EVALUATOR_MODEL=DeepSeek-V3.2-evaluator

# Base URL for Foundry: use the API endpoint from Azure Portal (Keys and Endpoint).
# Often one of:
#   https://<your-resource>.services.ai.azure.com/models/
#   https://<your-resource>.services.ai.azure.com/openai/v1/
# Include trailing slash. SDK appends chat/completions and api-version as needed.
EVALUATOR_API_BASE=https://your-resource.services.ai.azure.com/models/

# KEY 1 or KEY 2 from the Foundry resource (or the key that works with EVALUATOR_API_BASE).
EVALUATOR_API_KEY=your-evaluator-api-key

# API version for Foundry MaaS (adjust if Azure docs specify otherwise).
EVALUATOR_API_VERSION=2024-05-01-preview

EVALUATOR_TEMPERATURE=0.0

# ── Verifier — o1-mini (Azure OpenAI on cognitiveservices.azure.com) ───────────
# Deployment name must match the o1-mini deployment in Azure OpenAI Studio.
VERIFIER_MODEL=o1-mini-verifier

# Shared endpoint for Azure OpenAI (different host than *.services.ai.azure.com).
# Example shape:
AZURE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/

AZURE_API_VERSION=2024-12-01-preview

# Usually the same subscription key as shown under Keys and Endpoint for the resource.
AZURE_API_KEY=your-azure-openai-key

# Per-role overrides (optional — default to AZURE_* above)
VERIFIER_AZURE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
VERIFIER_AZURE_DEPLOYMENT=o1-mini-verifier
VERIFIER_AZURE_API_VERSION=2024-12-01-preview
VERIFIER_AZURE_API_KEY=your-azure-openai-key

# o1 / reasoning models: temperature must be 1.0; use a large max completion budget.
VERIFIER_AZURE_TEMPERATURE=1.0
VERIFIER_AZURE_MAX_TOKENS=16384

# ── Optional: shared overrides for evaluator if it ever uses azure_openai backend ─
# EVALUATOR_AZURE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
# EVALUATOR_AZURE_DEPLOYMENT=DeepSeek-V3.2-evaluator
# EVALUATOR_AZURE_API_KEY=your-key

# ── Local development only ───────────────────────────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434
