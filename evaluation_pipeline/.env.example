# ROARS environment template
# Copy this file to evaluation_pipeline/.env, then replace every placeholder
# with the credentials/endpoints provided by the project owner.
#
# Never commit evaluation_pipeline/.env or any real API key to GitHub.

# Final project defaults: MS3 + Prompt Set B + strict classification.
ROAR_PROMPT_SET=B_ChainOfThought
ROAR_MODEL_PROFILE=MS3_DeepSeek_o4mini
ROAR_CLASSIFICATION_STRATEGY=strict
MAX_ITERATIONS=2

# Evaluator: DeepSeek-V3.2 deployment through an OpenAI-compatible
# Azure AI Foundry MaaS endpoint.
EVALUATOR_BACKEND=openai
EVALUATOR_MODEL=DeepSeek-V3.2-evaluator
EVALUATOR_API_BASE=https://<your-foundry-resource>.services.ai.azure.com/models/
EVALUATOR_API_KEY=<your-evaluator-api-key>
EVALUATOR_API_VERSION=2024-05-01-preview
EVALUATOR_TEMPERATURE=0.0
EVALUATOR_MAX_TOKENS=4096

# Verifier: o4-mini deployment through Azure OpenAI.
VERIFIER_BACKEND=azure_openai
VERIFIER_MODEL=o4-mini-verifier
VERIFIER_AZURE_DEPLOYMENT=o4-mini-verifier
VERIFIER_AZURE_TEMPERATURE=1.0
VERIFIER_AZURE_MAX_TOKENS=16384

# Shared Azure OpenAI settings used by the verifier.
# VERIFIER_AZURE_ENDPOINT/API_KEY/API_VERSION are optional; if omitted, the
# verifier falls back to these shared AZURE_* values.
AZURE_ENDPOINT=https://<your-azure-openai-resource>.cognitiveservices.azure.com/
AZURE_API_VERSION=2025-01-01-preview
AZURE_API_KEY=<your-azure-openai-api-key>

# Optional runtime settings.
# ROAR_PIPELINE_TIMEOUT_MS=300000
# PYTHON=python
